rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * REGLAS ABIERTAS — cualquiera puede leer y escribir todo.
     * Solo para desarrollo / depuración. En producción, vuelve a reglas
     * que exijan auth y/o campos published.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
